generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Scale {
  LOW
  MILD
  SEVERE
  EMERGENCY
}
model User{
  userId String @id @default(uuid())
  name String
  username String @unique
  email String @unique
  phone String @default("0000000000")
  city String @default("Antartica")
  password String

  record History[]
}
model History{
  id String @id @default(uuid())
  description String 
  date DateTime @default(now())
  severity Scale @default(LOW)
  uid String

  createdBy User @relation(fields: [uid], references: [userId])
}